        { "expr": "rate(technitium_dns_queries_noerror_total{instance=~\"$target\",job=~\"$job\"}[$__rate_interval])", "legendFormat": "{{instance}} - NOERROR", "refId": "A" },
        { "expr": "rate(technitium_dns_queries_nxdomain_total{instance=~\"$target\",job=~\"$job\"}[$__rate_interval])", "legendFormat": "{{instance}} - NXDOMAIN", "refId": "B" },
        { "expr": "rate(technitium_dns_queries_servfail_total{instance=~\"$target\",job=~\"$job\"}[$__rate_interval])", "legendFormat": "{{instance}} - SERVFAIL", "refId": "C" },
        { "expr": "rate(technitium_dns_queries_refused_total{instance=~\"$target\",job=~\"$job\"}[$__rate_interval])", "legendFormat": "{{instance}} - REFUSED", "refId": "D" }
